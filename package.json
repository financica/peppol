{
	"name": "@financica/peppol",
	"version": "0.2.0",
	"description": "Peppol network toolkit for TypeScript: participant discovery via SML/SMP, Peppol Directory lookups, EAS schemes, and document-type classification.",
	"keywords": [
		"peppol",
		"e-invoicing",
		"einvoice",
		"sml",
		"smp",
		"ubl",
		"en16931",
		"eas",
		"vat"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/financica/peppol.git"
	},
	"bugs": "https://github.com/financica/peppol/issues",
	"homepage": "https://github.com/financica/peppol#readme",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./schemes": {
			"import": "./dist/schemes.js",
			"types": "./dist/schemes.d.ts"
		},
		"./document-types": {
			"import": "./dist/document-types.js",
			"types": "./dist/document-types.d.ts"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup",
		"prepack": "npm run build",
		"lint": "eslint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"type-check": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest --run",
		"test:coverage": "vitest --coverage",
		"ci": "npm run type-check && npm run lint && npm run test:run && npm run build"
	},
	"dependencies": {
		"fast-xml-parser": "^5.8.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"eslint": "^9.0.0",
		"prettier": "^3.8.1",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.0.0",
		"vitest": "^4.0.18"
	},
	"publishConfig": {
		"access": "public"
	},
	"prettier": {
		"printWidth": 88,
		"tabWidth": 4,
		"useTabs": true,
		"overrides": [
			{
				"files": "*.{yml,yaml}",
				"options": {
					"tabWidth": 2,
					"useTabs": false
				}
			}
		]
	}
}
